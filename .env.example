# Daily.co subdomain (required)
VITE_DAILY_SUBDOMAIN=your-subdomain

# Company branding
VITE_COMPANY_NAME=Root Ventures
VITE_COMPANY_URL=https://root.vc
VITE_ASSET_PATH=.

# Room-specific config (optional)
# Format: VITE_ROOM_{ROOMNAME}_{PROPERTY}
# VITE_ROOM_LEE_TITLE=Meeting with Lee
# VITE_ROOM_LEE_BACKGROUND=lee-bg.png

# Local e2e tests (optional)
# Set ONE of the following to enable `npm run test:e2e`:
#  - DAILY_API_KEY: from https://dashboard.daily.co/developers,
#    test will auto-create + destroy a temporary room.
#  - E2E_ROOM=my-room: test will join the existing `meet-my-room` room.
# DAILY_API_KEY=
# E2E_ROOM=e2e-test
